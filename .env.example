# Copy to .env and fill in. PRODUCTION (NODE_ENV=production) is hard-gated at
# boot by src/config/env.validation.ts and by `npm run prod:check` — it will
# REFUSE TO START unless ALL of the following hold:
#   • JWT_SECRET is strong (>=16 chars, not "change-me"/"dev-only")
#   • ENABLE_MOCK_DATA=false
#   • ENABLE_DEV_ENDPOINTS=false
#   • AUTHZ_MODE=enforce
#   • EVIDENCE_STORAGE_DIR is set to a writable, persistent, non-public path
# Run `npm run prod:check` with the production env before every deploy.
NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/edify_pm?schema=public"

JWT_SECRET="change-me"
JWT_EXPIRES_IN="12h"

# Object-level authorization mode. "shadow" computes the decision and LOGS
# would-be denials without blocking (safe for observation/online testing);
# "enforce" throws ForbiddenException on deny. MUST be "enforce" in production
# (boot fails otherwise). Default: shadow.
AUTHZ_MODE=shadow

# Maps Partner* roles onto a seeded partner org so the demo works before real
# User<->Partner linkage exists. MUST be false in real production. Default: true.
PARTNER_ROLE_BRIDGE=true

# Login lockout policy (per-account). Defaults: 5 failed attempts, 15-min lock.
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCK_MINUTES=15

ENABLE_MOCK_DATA=true
ENABLE_DEV_ENDPOINTS=true
ENABLE_SALESFORCE_INTEGRATION=false

ENABLE_BACKGROUND_JOBS=false
REDIS_URL="redis://localhost:6379"

# Comma-separated allowed CORS origins (the web app's public URL).
CORS_ORIGINS="http://localhost:3000"

# Where uploaded evidence files are written. On Railway, mount a persistent
# volume and point this at its mount path (e.g. /data/evidence).
EVIDENCE_STORAGE_DIR="uploads/evidence"
