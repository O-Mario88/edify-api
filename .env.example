# Copy to .env and fill in. Production must set NODE_ENV=production, a strong
# JWT_SECRET, ENABLE_MOCK_DATA=false, ENABLE_DEV_ENDPOINTS=false.
NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/edify_pm?schema=public"

JWT_SECRET="change-me"
JWT_EXPIRES_IN="12h"

ENABLE_MOCK_DATA=true
ENABLE_DEV_ENDPOINTS=true
ENABLE_SALESFORCE_INTEGRATION=false

ENABLE_BACKGROUND_JOBS=false
REDIS_URL="redis://localhost:6379"

# Comma-separated allowed CORS origins (the web app's public URL).
CORS_ORIGINS="http://localhost:3000"

# Where uploaded evidence files are written. On Railway, mount a persistent
# volume and point this at its mount path (e.g. /data/evidence).
EVIDENCE_STORAGE_DIR="uploads/evidence"
