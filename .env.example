# Copy to .env and fill in. Production must set NODE_ENV=production, a strong
# JWT_SECRET, ENABLE_MOCK_DATA=false, ENABLE_DEV_ENDPOINTS=false.
NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/edify_pm?schema=public"

JWT_SECRET="change-me"
JWT_EXPIRES_IN="12h"

ENABLE_MOCK_DATA=true
ENABLE_DEV_ENDPOINTS=true
ENABLE_SALESFORCE_INTEGRATION=false

ENABLE_BACKGROUND_JOBS=false
REDIS_URL="redis://localhost:6379"
